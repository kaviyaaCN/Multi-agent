# ==============================================================================
# 1. Groq API Key Configuration (Required)
# ==============================================================================
# Get your free API keys at: https://console.groq.com/keys
# The system supports automatic API key rotation! Provide up to 5 keys.
# If one key hits the rate limit (429), it instantly switches to the next.

GROQ_API_KEY_1=
GROQ_API_KEY_2=
GROQ_API_KEY_3=
GROQ_API_KEY_4=
GROQ_API_KEY_5=

# (Optional) Tavily API Key for dynamic context gathering
TAVILY_API_KEY=

# ==============================================================================
# 2. Model Selection (Optional)
# ==============================================================================
# Default Groq model for agents (Llama 3 is incredibly fast and smart)
GROQ_MODEL="llama-3.3-70b-versatile"

# ── Cache ──────────────────────────────────────────────────
CACHE_TTL=3600

# ── Logging ────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Embedding model (HuggingFace) ──────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Vector store path ──────────────────────────────────────
FAISS_INDEX_PATH=data/faiss_index
